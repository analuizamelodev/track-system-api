# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/track_system?schema=public"

# JWT
JWT_SECRET="change-me-in-production"

# Default admin (created on first startup if not exists)
DEFAULT_ADMIN_EMAIL="admin@empresa.com"
