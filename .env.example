# Mail (MailHog in development)
MAIL_HOST="localhost"
MAIL_PORT=1025
MAIL_FROM="noreply@tracksystem.com"

# Frontend tracking page base URL
TRACKING_BASE_URL="http://localhost:3001/tracking"

# Server
PORT=3000
