generator client {
  provider     = "prisma-client"
  output       = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role          Int     @default(2)
  active        Boolean @default(true)
  isTempPassword Boolean @default(true)

  shipments Shipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String     @id @default(uuid())
  name      String
  email     String?
  document  String?
  phone     String?
  shipments Shipment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Shipment {
  id           String @id @default(uuid())
  trackingCode String @unique
  status       Int    @default(1)
  serviceType  String
  weight       Float
  estimatedDelivery DateTime?

  // Remetente + Origem
  senderName          String
  originStreet        String
  originNumber        String
  originNeighborhood  String
  originCity          String
  originState         String
  originCep           String

  // Destinatário + Destino
  recipientName           String
  destinationStreet       String
  destinationNumber       String
  destinationNeighborhood String
  destinationCity         String
  destinationState        String
  destinationCep          String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  items          ShipmentItem[]
  recipient      Recipient?
  trackingEvents TrackingEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([customerId])
}

model TrackingEvent {
  id            String   @id @default(uuid())
  shipmentId    String
  shipment      Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status        Int
  description   String?
  location      String?
  changedById   String?
  changedByName String?
  createdAt     DateTime @default(now())

  @@index([shipmentId])
}

model Recipient {
  id           String  @id @default(uuid())
  shipmentId   String  @unique
  signedName   String
  deliveryCep  String
  phone        String?

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}

model ShipmentItem {
  id          String  @id @default(uuid())
  shipmentId  String
  name        String
  quantity    Int
  description String?

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}
