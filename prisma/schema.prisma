generator client {
  provider     = "prisma-client"
  output       = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  shipments Shipment[]
  createdAt DateTime   @default(now())
}

model Customer {
  id        String     @id @default(uuid())
  name      String
  document  String?
  phone     String?
  shipments Shipment[]
  createdAt DateTime   @default(now())
}

model Shipment {
  id           String @id @default(uuid())
  trackingCode String @unique
  status       Int    @default(1)
  origin       String
  destination  String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  items     ShipmentItem[]
  recipient Recipient?

  createdAt DateTime @default(now())
}

model Recipient {
  id         String  @id @default(uuid())
  shipmentId String  @unique
  name       String
  phone      String?
  address    String

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}

model ShipmentItem {
  id          String  @id @default(uuid())
  shipmentId  String
  name        String
  quantity    Int
  description String?

  shipment Shipment @relation(fields: [shipmentId], references: [id])
}
